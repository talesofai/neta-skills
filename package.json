{
  "name": "neta-skills",
  "version": "0.1.0",
  "description": "Neta API pi coding agent skills",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/talesofai/neta-skills.git"
  },
  "keywords": [
    "neta",
    "skills",
    "pi-coding-agent",
    "ai",
    "image-generation",
    "video-generation"
  ],
  "author": "Neta Team",
  "license": "MIT",
  "engines": {
    "node": ">=2.0.0"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "lint": "biome check . --write --unsafe",
    "validate:skill": "cd skills/neta && npm run validate",
    "type-check:skill": "cd skills/neta && npm run type-check",
    "check": "pnpm lint && pnpm type-check:skill && pnpm validate:skill",
    "dev:skills": "pnpm --filter @neta/skills-neta dev",
    "start:skills": "pnpm --filter @neta/skills-neta start",
    "build:skills": "pnpm --filter @neta/skills-neta build",
    "changelog": "changeset",
    "bump": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
